# ── NEXORA AI Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────────────────────────────
VITE_APP_NAME=NEXORA AI
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ── API ──────────────────────────────────────────────────────────────────
# Backend API base URL (leave empty to use mock data)
VITE_API_BASE_URL=
VITE_API_TIMEOUT=15000

# ── M-Pesa ───────────────────────────────────────────────────────────────
VITE_MPESA_PAYBILL=247247
VITE_MPESA_TILL=525900
VITE_MPESA_SHORTCODE=174379
VITE_MPESA_PASSKEY=

# ── AI ───────────────────────────────────────────────────────────────────
# LLM provider API key (for AI Assistant)
VITE_AI_API_KEY=
VITE_AI_MODEL=

# ── Analytics ────────────────────────────────────────────────────────────
VITE_ANALYTICS_ID=

# ── Feature Flags ────────────────────────────────────────────────────────
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true
