# ── NEXORA AI — Environment Variables ──────────────────────────────────────
# Anything prefixed with VITE_ is inlined into the client bundle and is
# PUBLIC. Never put secrets (API keys, M-Pesa passkeys, JWT secrets) in
# VITE_ vars — those belong on the backend only.

# ── Client (safe to ship) ──────────────────────────────────────────────────
VITE_APP_NAME=NEXORA AI
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
VITE_DEFAULT_LOCALE=en-KE
VITE_SUPPORTED_LOCALES=en-KE,sw-KE

# Backend base URL (proxy in dev, real API in prod). Empty -> mock mode.
VITE_API_BASE_URL=
VITE_API_TIMEOUT=15000

# Public M-Pesa identifiers (paybill/till/shortcode are NOT secrets)
VITE_MPESA_PAYBILL=247247
VITE_MPESA_TILL=525900
VITE_MPESA_SHORTCODE=174379

# WhatsApp Business — public phone number used for deep links
VITE_WHATSAPP_NUMBER=

# Sentry public DSN (intentionally public)
VITE_SENTRY_DSN=

# Feature flags
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_CHAMA=true
VITE_ENABLE_OFFLINE_POS=true
VITE_ENABLE_ETIMS=true

# ── Server-only (DO NOT prefix with VITE_) ────────────────────────────────
# These never reach the client. They live on the backend `.env` only.
# Listed here for documentation; the frontend never reads them.
#
#   AI_API_KEY=
#   AI_MODEL=
#   MPESA_CONSUMER_KEY=
#   MPESA_CONSUMER_SECRET=
#   MPESA_PASSKEY=
#   KRA_ETIMS_API_KEY=
#   JWT_SECRET=
#   DATABASE_URL=
